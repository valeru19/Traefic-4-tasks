FROM python:3.11-slim

# WORKDIR — рабочая директория внутри контейнера
# Все последующие команды выполняются в /app
WORKDIR /app

# COPY <источник на хосте> <назначение в контейнере>
# Сначала копируем только файл зависимостей
COPY requirements.txt .

# RUN — выполнить команду при сборке образа
# pip install -r requirements.txt — установить все зависимости
# --no-cache-dir — не кешировать скачанные пакеты (экономим место)
RUN pip install --no-cache-dir -r requirements.txt

# Теперь копируем весь остальной код приложения
# (этот слой пересобирается при любом изменении кода)
COPY . .

# EXPOSE — документирует, какой порт слушает приложение
# Это лишь метаданные, реальный проброс портов настраивается в compose
EXPOSE 5000

# CMD — команда, которая запускается при старте контейнера
# Используем gunicorn (production WSGI сервер) вместо flask run
# -w 2        — 2 рабочих процесса
# -b 0.0.0.0:5000 — слушать на всех интерфейсах, порт 5000
# app:app     — модуль "app", объект Flask "app" внутри него
CMD ["python", "app.py"]